# Browser and SSR Supabase auth configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here

# Server-only Supabase configuration for privileged bridge and storage operations
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Membership expiry reminder emails
RESEND_API_KEY=your_resend_api_key_here
MEMBERSHIP_EXPIRY_EMAIL_FROM="Evolutionz Fitness <reminders@example.com>"
RESEND_DAILY_EMAIL_LIMIT=100
NEXT_PUBLIC_RESEND_DAILY_EMAIL_LIMIT=100
CRON_SECRET=your_vercel_cron_secret_here

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
# Contributors: set VAPID_SUBJECT to your own contact email (mailto:) so push providers can reach you if something goes wrong.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_SUBJECT=mailto:you@example.com
